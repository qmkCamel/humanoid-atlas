{
  "rewrites": [
    { "source": "/((?!api|models|demos|favicon|og-image|robots|sitemap|llms).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/models/(.*).ply",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
